# Example env vars for local development
# ⚠️ CRITICAL: For asyncpg + Supabase to work, you MUST:
# 1. Use the DIRECT connection (port 5432), NOT the transaction pooler (port 6543)
# 2. Use the FULL hostname (not an IP address) — asyncpg needs SNI
# 3. Include sslmode=require — SSL enables SNI which routes to correct Supabase tenant
# 4. Use postgresql+asyncpg:// dialect (NOT postgresql://)
# 5. Get the URL from: https://supabase.com/dashboard → Settings → Database → "Connection string" tab → "URI"

# ⬇️ UPDATE THIS with the correct Supabase direct connection string from your dashboard:
# Format: postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agentic_rag
# Local SQLite alt: DATABASE_URL=sqlite+aiosqlite:///backend/tmp/agentic_rag_dev.db
REDIS_URL=redis://localhost:6379/0
CHROMA_DB_DIR=backend/chroma_db
# OPENAI_API_KEY is optional — if set, OpenAI embeddings will be used instead of local
# OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
# Groq OpenAI-compatible endpoint
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
PLANNER_MODEL=llama-3.1-8b-instant
SYNTH_MODEL=llama-3.3-70b-versatile

# App
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Auth
SECRET_KEY=your_secure_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ADMIN_EMAILS=admin@example.com

# Rate limits
RATE_LIMIT_PER_HOUR=100
UPLOAD_LIMIT_PER_HOUR=20

# Upload limits
MAX_UPLOAD_MB=20

# Local dev: skip JWT checks (backend) and login gate (frontend)
DISABLE_AUTH=1
NEXT_PUBLIC_DISABLE_AUTH=1
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Local embeddings for ingest + retrieval (no OpenAI key required)
ENABLE_SENTENCE_TRANSFORMERS=1
EMBEDDING_MODEL=all-MiniLM-L6-v2
HF_TOKEN=your_token_here
