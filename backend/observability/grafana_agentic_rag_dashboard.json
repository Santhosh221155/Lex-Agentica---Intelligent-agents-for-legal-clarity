{
  "annotations": {"list": []},
  "panels": [
    {
      "type": "graph",
      "title": "HTTP Requests/sec",
      "targets": [{"expr": "rate(agentic_requests_total[1m])", "legendFormat": "requests/s"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "graph",
      "title": "Retrieval latency (ms)",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(retrieval_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "graph",
      "title": "LLM latency (ms)",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(llm_latency_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "graph",
      "title": "Tokens generated / minute",
      "targets": [{"expr": "increase(llm_tokens_generated_total[1m])", "legendFormat": "tokens/min"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    }
  ],
  "title": "Agentic RAG - Metrics",
  "schemaVersion": 16
}
